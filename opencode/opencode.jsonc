{
  "$schema": "https://opencode.ai/config.json",
  "agent": {
    "explore": {
      "model": "github-copilot/gpt-5.4-mini"
    }
  },
  "compaction": {
    "auto": false,
    "prune": false
  },
  "mcp": {
    "atlassian": {
      "enabled": false,
      "type": "remote",
      "url": "https://mcp.atlassian.com/v1/mcp"
    },
    "datadog": {
      "enabled": true,
      "type": "remote",
      "url": "https://mcp.datadoghq.eu/api/unstable/mcp-server/mcp?toolsets=core,apm,software-delivery"
    },
    "executor": {
      "enabled": false,
      "type": "remote",
      "url": "http://127.0.0.1:8788/mcp"
    },
    "fff": {
      "command": [
        "fff-mcp"
      ],
      "enabled": true,
      "type": "local"
    },
    "github": {
      "command": [
        "/Users/stephen.collings/dotfiles/opencode-commands/github.sh"
      ],
      "enabled": false,
      "type": "local"
    },
    "grep_app": {
      "enabled": true,
      "type": "remote",
      "url": "https://mcp.grep.app"
    },
    "kubernetes": {
      "command": [
        "npx",
        "-y",
        "@mettle/boxed-kubernetes-mcp-server"
      ],
      "enabled": false,
      "type": "local"
    },
    "kubeview": {
      "command": [
        "npx",
        "-y",
        "kubeview-mcp"
      ],
      "enabled": false,
      "environment": {
        "MCP_MODE": "code"
      },
      "type": "local"
    },
    "kubeview_mcp": {
      "command": [
        "npx",
        "-y",
        "kubeview-mcp"
      ],
      "enabled": false,
      "environment": {
        "MCP_MODE": "tools"
      },
      "type": "local"
    },
    "maven": {
      "command": [
        "npx",
        "-y",
        "@mettle/boxed-maven-mcp-server"
      ],
      "enabled": true,
      "type": "local"
    },
    "opensrc": {
      "command": [
        "npx",
        "-y",
        "opensrc-mcp"
      ],
      "enabled": true,
      "type": "local"
    },
    "overseer": {
      "command": [
        "npx",
        "-y",
        "@dmmulroy/overseer",
        "mcp"
      ],
      "enabled": false,
      "type": "local"
    },
    "snyk": {
      "command": [
        "npx",
        "-y",
        "@mettle/boxed-snyk-mcp-server"
      ],
      "enabled": false,
      "type": "local"
    }
  },
  "permission": {
    "atlassian_*": "deny",
    "bash": {
      "gh api *": "allow"
    },
    "datadog_*": "deny"
  },
  "plugin": [
    "@xesrevinu/opencode-jj-enforcer@0.1.2",
    "/Users/stephen.collings/.boxedcode-pro/0.12.0/boxedcode-pro",
    "@slkiser/opencode-quota@2.1.0"
  ],
  "skills": {
    "paths": [
      "~/.github/skills",
      ".github/skills"
    ]
  }
}
